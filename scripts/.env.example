# Copier en .env puis remplir : cp .env.example .env

# Prénom (sert au nom de l'app : api-appservice-<PRENOM>)
PRENOM=votre_prenom

# Groupe de ressources personnel (existant)
RESOURCE_GROUP=rg-votre-prenom-prf2026

# Plan App Service partagé de la formation.
# Si le plan est dans un AUTRE groupe, utiliser son resource ID complet :
#   az appservice plan show --name <plan> --resource-group <rg-du-plan> --query id -o tsv
APP_SERVICE_PLAN=/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/rg-shared-prf2026/providers/Microsoft.Web/serverfarms/plan-npr-prf2026
